# Used only when running bridge outside Docker (npm start)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/whatsapp-crm
N8N_HEALTH_URL=http://localhost:5678/healthz
PORT=3001
WEBHOOK_RETRIES=3

# REQUIRED — protects /qr and /send (n8n uses x-api-token with this value)
# QR_ACCESS_TOKEN=some-random-secret

# REQUIRED for Media Assets UI only (/assets-ui, upload, delete)
# Use a simple URL-safe token (letters, numbers, hyphens) — no @ % ^ ! characters
# ASSETS_UI_TOKEN=skillvard-assets-k9mP2xQ7

# Inbound media saved from WhatsApp; n8n pulls via MEDIA_BASE_URL/media/:file?token=...
MEDIA_DIR=./media
MEDIA_BASE_URL=http://127.0.0.1:3001
MEDIA_MAX_MB=15
MEDIA_TTL_DAYS=14

# Outbound sends (brochure PDF, images, audio, video)
ASSETS_DIR=./assets
SEND_MAX_MB=64

# Optional: only forward specific numbers (comma-separated, digits only)
# ALLOWLIST=919876543210
