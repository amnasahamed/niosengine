# --- Bridge-only deploy (existing n8n + Traefik on this server) ---

# Internal URLs — bridge talks to existing n8n container on Docker network
N8N_WEBHOOK_URL=http://n8n:5678/webhook/whatsapp-crm
N8N_HEALTH_URL=http://n8n:5678/healthz
WEBHOOK_RETRIES=3

# REQUIRED — protects /qr, /send, and /media
QR_ACCESS_TOKEN=change-me-qr-token

# Used in n8n "Send WhatsApp Reply" node header (same value as above)
# BRIDGE_SEND_URL=http://niostech-whatsapp:3001/send

# Media download (voice / images) — n8n fetches via media_url on Docker network
MEDIA_BASE_URL=http://niostech-whatsapp:3001
MEDIA_MAX_MB=15
MEDIA_TTL_DAYS=14

# Optional: only forward specific numbers (comma-separated)
# ALLOWLIST=919876543210
