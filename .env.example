# --- n8n public URL (required when behind reverse proxy + SSL) ---
N8N_HOST=n8n.yourdomain.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.yourdomain.com/
N8N_PROXY_HOPS=1
N8N_SECURE_COOKIE=true

# n8n login — REQUIRED (docker-compose will refuse to start without this)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong-password

# Timezone
TZ=Asia/Kolkata
GENERIC_TIMEZONE=Asia/Kolkata

# --- WhatsApp bridge (internal Docker network — do not change unless you know why) ---
N8N_WEBHOOK_URL=http://n8n:5678/webhook/whatsapp-crm
N8N_HEALTH_URL=http://n8n:5678/healthz
WEBHOOK_RETRIES=3

# REQUIRED — protects /qr, /send, and /media
QR_ACCESS_TOKEN=change-me-qr-token

# Media downloads (voice notes, images) for n8n Whisper later
MEDIA_BASE_URL=http://niostech-whatsapp:3001
MEDIA_MAX_MB=15
MEDIA_TTL_DAYS=14

# Outbound brochure/images/audio/video (drop files in whatsapp-bridge/assets/)
SEND_MAX_MB=64

# Optional: only forward specific numbers (comma-separated, digits only)
# ALLOWLIST=919876543210
